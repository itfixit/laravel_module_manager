{
    "name": "itfixit/laravel-module-manager",
    "description": "Laravel Module Management",
    "type": "laravel",
    "authors": [
        {
            "name": "mrabbani",
            "email": "mahbub.rucse@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0 || ^8.1 || ^8.2 || ^8.3 || ^8.4 || ^8.5",
        "illuminate/console": "^6|^7|^8|^9|^10|^11|^12|^13",
        "illuminate/database": "^6|^7|^8|^9|^10|^11|^12|^13"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Mrabbani\\ModuleManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mrabbani\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mrabbani\\ModuleManager\\Providers\\ModuleProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "dev",
    "license": "MIT"
}
